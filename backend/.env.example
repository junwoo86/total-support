# ============================================================
# .env 템플릿 — 실제 값은 .env에 작성 (커밋 금지)
# ============================================================

# --- PostgreSQL ----------------------------------------------
TS_DB_HOST=
TS_DB_PORT=5432
TS_DB_NAME=biocom
TS_DB_USER=
TS_DB_PASSWORD=
TS_DATABASE_URL=postgresql+psycopg://USER:PASSWORD@HOST:5432/biocom
TS_DB_STATEMENT_TIMEOUT_MS=30000

# --- Redis ---------------------------------------------------
TS_REDIS_URL=redis://localhost:6379/0
TS_CELERY_BROKER_URL=redis://localhost:6379/1
TS_CELERY_RESULT_BACKEND=redis://localhost:6379/2

# --- Slack ---------------------------------------------------
TS_SLACK_WEBHOOK_URL=

# --- 운영 설정 -----------------------------------------------
TS_ENV=development
TS_LOG_LEVEL=INFO
TS_TZ=Asia/Seoul

# --- Vertex AI Gemini (본문 요약, 옵션) ----------------------
# TS_GCP_PROJECT_ID 가 비어있으면 요약기는 비활성 — 기존 동작 그대로.
# 활성화하려면:
#   1) gcloud auth application-default login (로컬) 또는
#      서비스 계정 바인딩 (Cloud Run) 으로 ADC 설정
#   2) 아래 PROJECT_ID 입력
TS_GCP_PROJECT_ID=
TS_GCP_REGION=asia-northeast3
# Gemini 는 별도 global endpoint 사용 (Biocom-lab 최신 패턴)
TS_GEMINI_LOCATION=global
TS_GEMINI_MODEL=gemini-3.5-flash
TS_GEMINI_TIMEOUT_S=30
TS_GEMINI_MAX_INPUT_CHARS=8000

# ============================================================
# .env 템플릿 — 실제 값은 .env에 작성 (커밋 금지)
# ============================================================

# --- PostgreSQL ----------------------------------------------
TS_DB_HOST=
TS_DB_PORT=5432
TS_DB_NAME=biocom
TS_DB_USER=
TS_DB_PASSWORD=
TS_DATABASE_URL=postgresql+psycopg://USER:PASSWORD@HOST:5432/biocom
TS_DB_STATEMENT_TIMEOUT_MS=30000

# --- Redis ---------------------------------------------------
TS_REDIS_URL=redis://localhost:6379/0
TS_CELERY_BROKER_URL=redis://localhost:6379/1
TS_CELERY_RESULT_BACKEND=redis://localhost:6379/2

# --- Slack ---------------------------------------------------
TS_SLACK_WEBHOOK_URL=

# --- 운영 설정 -----------------------------------------------
TS_ENV=development
TS_LOG_LEVEL=INFO
TS_TZ=Asia/Seoul
